{
  "name": "color-calibration-extension",
  "displayName": "Color Calibration Theme Probe",
  "description": "VS Code/Cursor theme detection PoC for the color calibration MVP.",
  "version": "0.0.1",
  "publisher": "local-poc",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:colorCalibration.printThemeProbe",
    "onCommand:colorCalibration.printThemeSignalReport",
    "onCommand:colorCalibration.openBeforeAfterPreview",
    "onCommand:colorCalibration.applyHardcodedPatch",
    "onCommand:colorCalibration.rollbackHardcodedPatch"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "colorCalibration.printThemeProbe",
        "title": "Color Calibration: Print Theme Probe"
      },
      {
        "command": "colorCalibration.printThemeSignalReport",
        "title": "Color Calibration: Print Theme Signal Report"
      },
      {
        "command": "colorCalibration.openBeforeAfterPreview",
        "title": "Color Calibration: Open Before/After Preview"
      },
      {
        "command": "colorCalibration.applyHardcodedPatch",
        "title": "Color Calibration: Apply Hardcoded Patch PoC"
      },
      {
        "command": "colorCalibration.rollbackHardcodedPatch",
        "title": "Color Calibration: Rollback Hardcoded Patch PoC"
      }
    ]
  },
  "scripts": {
    "clean": "node -e \"require('fs').rmSync('out', { recursive: true, force: true })\"",
    "compile": "tsc -p .",
    "test": "npm run compile && node --test"
  },
  "devDependencies": {
    "@types/node": "^18.19.130",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.4.5"
  }
}
