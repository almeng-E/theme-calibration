{
  "name": "color-calibration-extension",
  "displayName": "Color Calibration Theme Probe",
  "description": "Color Calibration Extension for VS Code and Cursor.",
  "version": "0.0.1",
  "publisher": "local-poc",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:colorCalibration.openEditorViewer",
    "onCommand:colorCalibration.rollbackCandidatePatch"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "colorCalibration.openEditorViewer",
        "title": "Color Calibration: Open Editor Viewer"
      }
    ]
  },
  "scripts": {
    "clean": "node -e \"require('fs').rmSync('out', { recursive: true, force: true })\"",
    "compile": "tsc -p .",
    "test": "npm run compile && node --test"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@types/node": "^18.19.130",
    "@types/vscode": "^1.85.0",
    "jsdom": "^29.1.1",
    "typescript": "^5.4.5"
  }
}
